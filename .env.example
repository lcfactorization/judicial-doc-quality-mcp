# Judicial Document Quality MCP Server Configuration
# Copy this file to .env and modify as needed

# Skills directory (defaults to ../skills relative to src/)
# SKILLS_DIR=./skills

# Anchors directory (defaults to ../anchors relative to src/)
# ANCHORS_DIR=./anchors

# Verbose logging (true/false)
# VERBOSE=false

# Maximum total anomaly deduction (default: 50)
# ANOMALY_MAX_DEDUCTION=50

# Maximum total innovation bonus (default: 30)
# INNOVATION_MAX_BONUS=30

# Anomaly MCP integration
# Set to true when judicial-doc-anomaly-mcp (judicial-lint) is configured in your MCP client
# Recommended: install from https://github.com/lcfactorization/judicial-doc-anomaly-mcp
# This project provides 16-dimension anomaly detection that integrates with quality assessment:
#   - procedure: 程序异常
#   - evidence: 证据异常
#   - fact_finding: 事实认定异常
#   - focus_drift: 焦点漂移
#   - law_application: 法律适用异常
#   - discretion: 自由裁量权滥用
#   - rhetoric_trick: 修辞技巧异常
#   - logic: 逻辑异常
#   - temporal: 时间一致性异常
#   - trial_process: 审理过程异常
#   - external_interference: 外部干预
#   - execution: 执行异常
#   - negative_space: 负空间（缺失信息）异常
#   - semantic_drift: 语义漂移
#   - case_deviation: 类案偏离
#   - coupling: 惯性耦合
# ANOMALY_MCP_AVAILABLE=false

# Rule engine: enable/disable structural anomaly pre-screening
# RULE_ENGINE_ENABLED=true

# Evasive pattern detection: enable/disable
# EVASIVE_DETECTION_ENABLED=true
